# LLM Provider: ollama, gemini, groq, openrouter
LLM_PROVIDER=ollama

# Ollama settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# Cloud API keys (get free tier keys — see setup wizard)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Cloud model overrides (sensible defaults used if blank)
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
