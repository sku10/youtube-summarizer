# LLM Provider: ollama, gemini, groq, openrouter
LLM_PROVIDER=ollama

# Ollama settings (local or cloud)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
# OLLAMA_NUM_CTX=8192  # context window override (default: auto by Ollama based on RAM/VRAM)
# OLLAMA_API_KEY=      # only needed for Ollama cloud (https://ollama.com/settings/keys)
# For Ollama cloud, set: OLLAMA_URL=https://ollama.com

# Cloud API keys (get free tier keys — see setup wizard)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Cloud model overrides (sensible defaults used if blank)
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Proxy for YouTube requests (if your IP is blocked)
# YOUTUBE_PROXY=http://your-server:8888
# YOUTUBE_PROXY=socks5://your-server:1080
